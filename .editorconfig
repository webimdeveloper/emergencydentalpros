root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# PHP follows WordPress Coding Standards (tabs)
[*.php]
indent_style = tab
indent_size = 4

# JS / CSS / JSON use spaces
[*.{js,mjs,cjs,css,json,jsonc}]
indent_style = space
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown — preserve trailing spaces (line breaks)
[*.md]
trim_trailing_whitespace = false
